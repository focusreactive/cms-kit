{
  "$schema": "https://turborepo.org/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "globalEnv": [
    "NEXT_PUBLIC_*",
    "SB_*",
    "SANITY_*",
    "NODE_ENV",
    "VERCEL_ENV",
    "VERCEL_REDEPLOY_HOOK_URL",
    "DATABASE_URI",
    "PAYLOAD_SECRET",
    "AUTH0_SECRET",
    "AUTH0_BASE_URL",
    "AUTH0_ISSUER_BASE_URL",
    "AUTH0_CLIENT_ID",
    "AUTH0_CLIENT_SECRET",
    "BLOB_READ_WRITE_TOKEN",
    "EDGE_CONFIG"
  ],
  "tasks": {
    "build": {
      "cache": true,
      "persistent": true,
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": ["VERCEL_REDEPLOY_HOOK_URL"]
    },
    "start": {
      "dependsOn": ["^build"]
    },
    "lint": {
      "cache": true,
      "persistent": true
    },
    "typecheck": {},
    "dev": {
      "cache": false,
      "persistent": true
    },
    "dev:turbo": {
      "cache": false,
      "persistent": true
    },
    "@focus-reactive/sanity-template-selector#build": {
      "persistent": false,
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "sanity#build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "generate:types": {
      "cache": false
    },
    "generate:importmap": {
      "cache": false
    },
    "devsafe": {
      "cache": false,
      "persistent": true
    },
    "generate:experiments": {
      "cache": false
    }
  }
}
